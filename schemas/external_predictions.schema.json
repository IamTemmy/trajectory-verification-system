{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/IamTemmy/trajectory-verification-system/schemas/external_predictions.schema.json",
  "title": "External Motion Prediction Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "provenance", "predictions"],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model_name",
        "model_version",
        "source_repository",
        "source_revision",
        "checkpoint_sha256",
        "coordinate_frame",
        "future_data_used"
      ],
      "properties": {
        "model_name": {"type": "string", "minLength": 1},
        "model_version": {"type": "string", "minLength": 1},
        "source_repository": {"type": "string", "minLength": 1},
        "source_revision": {"type": "string", "minLength": 1},
        "checkpoint_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "coordinate_frame": {"const": "scenario_global"},
        "future_data_used": {"const": false}
      }
    },
    "predictions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["scenario_id", "agents"],
        "properties": {
          "scenario_id": {"type": "string", "minLength": 1},
          "agents": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["agent_id", "modes"],
              "properties": {
                "agent_id": {"type": "string", "minLength": 1},
                "modes": {
                  "type": "array",
                  "minItems": 1,
                  "maxItems": 6,
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["confidence", "xy_m"],
                    "properties": {
                      "confidence": {"type": "number", "minimum": 0},
                      "xy_m": {
                        "type": "array",
                        "minItems": 16,
                        "maxItems": 16,
                        "items": {
                          "type": "array",
                          "minItems": 2,
                          "maxItems": 2,
                          "items": {"type": "number"}
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
